{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "api/*.py": {
      "runtime": "python3.9",
      "maxDuration": 60
    }
  },
  "env": {
    "GROQ_API_KEY": "@groq_api_key",
    "GOOGLE_API_KEY": "@google_api_key",
    "AUTH_SECRET": "@auth_secret"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_BASE": ""
    }
  }
}
