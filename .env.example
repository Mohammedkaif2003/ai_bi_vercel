# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required for AI narration. Configure at least one supported provider.
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Required in production. Use a long random value.
AUTH_SECRET=change-me-in-production

# Optional production hardening.
ALLOWED_ORIGINS=https://your-domain.example
ALLOW_DEMO_USERS=false
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
ADMIN_DISPLAY_NAME=Administrator
# Or provide a complete user map:
# AUTH_USERS_JSON={"admin":{"password_hash":"sha256_hex_hash","display_name":"Administrator","role":"admin"}}
MAX_BODY_BYTES=8388608
MAX_CSV_BYTES=6291456
MAX_CSV_ROWS=20000
MAX_CSV_COLUMNS=200
AUTH_TOKEN_TTL_SECONDS=86400

# For local Streamlit development only. Not used by the Vercel deployment.
# STREAMLIT_SERVER_PORT=8501
