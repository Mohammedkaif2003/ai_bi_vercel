# Required for AI narration (at least one of these must be set)
GROQ_API_KEY=your_groq_api_key_here
GOOGLE_API_KEY=your_google_api_key_here   # optional fallback

# Auth token signing secret — change this in production!
AUTH_SECRET=change-me-in-production

# For local Streamlit development only (not used by the Vercel deployment)
# STREAMLIT_SERVER_PORT=8501
